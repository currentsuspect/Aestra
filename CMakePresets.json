{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "headless",
      "displayName": "Headless (no UI, container-friendly)",
      "inherits": "base",
      "cacheVariables": {
        "AESTRA_HEADLESS_ONLY": "ON"
      }
    },
    {
      "name": "full",
      "displayName": "Full app (UI + tests default)",
      "inherits": "base",
      "cacheVariables": {
        "AESTRA_HEADLESS_ONLY": "OFF"
      }
    },
    {
      "name": "full-fast",
      "displayName": "Full app (UI, tests OFF for faster/confident builds)",
      "inherits": "base",
      "cacheVariables": {
        "AESTRA_HEADLESS_ONLY": "OFF",
        "AESTRA_ENABLE_TESTS": "OFF"
      }
    },
    {
      "name": "lowmem",
      "displayName": "Low-memory build (4GB RAM laptop)",
      "inherits": "base",
      "cacheVariables": {
        "AESTRA_HEADLESS_ONLY": "OFF",
        "AESTRA_ENABLE_TESTS": "OFF",
        "AESTRA_LOW_MEMORY_BUILD": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "headless-release",
      "displayName": "Build AestraHeadless (Release)",
      "configurePreset": "headless",
      "configuration": "Release",
      "targets": [
        "AestraHeadless"
      ],
      "jobs": 0
    },
    {
      "name": "headless-debug",
      "displayName": "Build AestraHeadless (Debug)",
      "configurePreset": "headless",
      "configuration": "Debug",
      "targets": [
        "AestraHeadless"
      ],
      "jobs": 0
    },
    {
      "name": "full-release",
      "displayName": "Build full solution (Release)",
      "configurePreset": "full",
      "configuration": "Release",
      "jobs": 0
    },
    {
      "name": "full-fast-release",
      "displayName": "Build full app fast (Release)",
      "configurePreset": "full-fast",
      "configuration": "Release",
      "jobs": 0
    },
    {
      "name": "lowmem-release",
      "displayName": "Build low-mem (Release, 2 jobs)",
      "configurePreset": "lowmem",
      "configuration": "Release",
      "jobs": 2
    }
  ]
}
