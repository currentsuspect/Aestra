{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "headless",
      "displayName": "Headless (no UI, container-friendly)",
      "inherits": "base",
      "cacheVariables": {
        "NOMAD_HEADLESS_ONLY": "ON"
      }
    },
    {
      "name": "full",
      "displayName": "Full app (UI + tests default)",
      "inherits": "base",
      "cacheVariables": {
        "NOMAD_HEADLESS_ONLY": "OFF"
      }
    },
    {
      "name": "full-fast",
      "displayName": "Full app (UI, tests OFF for faster/confident builds)",
      "inherits": "base",
      "cacheVariables": {
        "NOMAD_HEADLESS_ONLY": "OFF",
        "NOMAD_ENABLE_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "headless-release",
      "displayName": "Build NomadHeadless (Release)",
      "configurePreset": "headless",
      "configuration": "Release",
      "targets": ["NomadHeadless"],
      "jobs": 0
    },
    {
      "name": "headless-debug",
      "displayName": "Build NomadHeadless (Debug)",
      "configurePreset": "headless",
      "configuration": "Debug",
      "targets": ["NomadHeadless"],
      "jobs": 0
    },
    {
      "name": "full-release",
      "displayName": "Build full solution (Release)",
      "configurePreset": "full",
      "configuration": "Release",
      "jobs": 0
    },
    {
      "name": "full-fast-release",
      "displayName": "Build full app fast (Release)",
      "configurePreset": "full-fast",
      "configuration": "Release",
      "jobs": 0
    }
  ]
}
